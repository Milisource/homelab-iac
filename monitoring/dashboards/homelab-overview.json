{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "datasource", "id": "loki", "name": "Loki" }
  ],
  "title": "Homelab Overview",
  "tags": ["homelab"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 10,
  "uid": "homelab-overview",
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "query": "label_values(node_load1, instance)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "label": "Node"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "100 - (avg by(hostname) (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$node\", hostname!=\"\"}[5m])) * 100)",
        "legendFormat": "{{ hostname }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean"] }
      }
    },
    {
      "id": 2,
      "title": "Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "100 * (1 - avg by(hostname) (node_memory_MemAvailable_bytes{instance=~\"$node\", hostname!=\"\"}) / avg by(hostname) (node_memory_MemTotal_bytes{instance=~\"$node\", hostname!=\"\"}))",
        "legendFormat": "{{ hostname }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean"] }
      }
    },
    {
      "id": 3,
      "title": "Load (15m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "avg by(hostname) (node_load15{instance=~\"$node\", hostname!=\"\"})",
        "legendFormat": "{{ hostname }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never", "fillOpacity": 20 }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean"] }
      }
    },
    {
      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "avg by(hostname) (time() - node_boot_time_seconds{instance=~\"$node\", hostname!=\"\"})",
        "legendFormat": "{{ hostname }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 3600 }
          ]}
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 5,
      "title": "Nodes Online",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "count(count by(hostname) (node_boot_time_seconds{instance=~\"$node\", hostname!=\"\"}))",
        "legendFormat": "",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "mappings": [
            { "type": "value", "value": "3", "text": "3/3 Online" },
            { "type": "value", "value": "2", "text": "2/3 Online" },
            { "type": "range", "from": 0, "to": 1, "text": "1/3 Online" }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background"
      }
    },
    {
      "id": 6,
      "title": "Disk — Root",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "avg by(hostname) (100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/\", instance=~\"$node\", hostname!=\"\", fstype!=\"\"} / on(instance) group_left(hostname) node_filesystem_size_bytes{mountpoint=\"/\", instance=~\"$node\", hostname!=\"\", fstype!=\"\"}))",
        "legendFormat": "{{ hostname }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]}
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 7,
      "title": "Disk by Mount",
      "type": "table",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "100 * (1 - node_filesystem_avail_bytes{instance=~\"$node\", hostname!=\"\", mountpoint!~\"/boot|/run|/snap|/proc|/sys|/dev\"} / on(instance, mountpoint) group_left(hostname) node_filesystem_size_bytes{instance=~\"$node\", hostname!=\"\", mountpoint!~\"/boot|/run|/snap|/proc|/sys|/dev\"})",
        "legendFormat": "{{ hostname }} {{ mountpoint }}",
        "refId": "A",
        "format": "table",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]},
          "custom": { "align": "auto" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Used %" },
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Used %", "desc": true }] }
    },
    {
      "id": 8,
      "title": "Net — Receive",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by(hostname) (rate(node_network_receive_bytes_total{instance=~\"$node\", hostname!=\"\", device=\"eth0\"}[5m]))",
        "legendFormat": "{{ hostname }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean"] }
      }
    },
    {
      "id": 9,
      "title": "Net — Transmit",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by(hostname) (rate(node_network_transmit_bytes_total{instance=~\"$node\", hostname!=\"\", device=\"eth0\"}[5m]))",
        "legendFormat": "{{ hostname }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom", "calcs": ["mean"] }
      }
    }
  ]
}
