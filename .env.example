# ═══════════════════════════════════════════════════════════════
# Homelab IaC — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Secrets use Docker Swarm secrets where noted; others use
# environment variables referenced as ${VAR} in compose files.
# ═══════════════════════════════════════════════════════════════

# ── Traefik ─────────────────────────────────────────────────────
# Let's Encrypt account email for certificate notifications
ACME_EMAIL=your-email@example.com

# ── Cloudflare API (Traefik DNS-01 challenge) ──────────────────
# Create a Cloudflare API token with DNS:Edit permission on your zone.
#   https://dash.cloudflare.com/profile/api-tokens
# Stored as a Docker Swarm secret:
#   echo "<token>" | docker secret create cf_dns_api_token -
CF_DNS_API_TOKEN=

# ── CrowdSec ───────────────────────────────────────────────────
# Bouncer API key for Traefik forwardAuth integration.
CROWDSEC_BOUNCER_API_KEY=
# CrowdSec LAPI host:port (the agent that runs the bouncer)
CROWDSEC_AGENT_HOST=192.168.50.122:8585

# ── Traefik Dashboard ──────────────────────────────────────────
# Basic auth users for the dashboard. Generate with:
#   echo $(htpasswd -nb admin your-password)
TRAEFIK_DASHBOARD_USERS=

# ── Keepalived (VRRP VIP failover) ──────────────────────────────
# Shared authentication password for VRRP advertisements.
# Must match on all nodes in the failover group.
KEEPALIVED_AUTH_PASS=

# ── Vaultwarden ────────────────────────────────────────────────
VAULTWARDEN_ADMIN_TOKEN=

# ── Grafana ─────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=

# ── SearXNG ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SEARXNG_SECRET=

# ── Navidrome (Last.fm integration) ─────────────────────────────
NAVIDROME_LASTFM_APIKEY=
NAVIDROME_LASTFM_SECRET=

# ── Open WebUI ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
OPENWEBUI_SECRET_KEY=
# SearXNG query URL for RAG search
SEARXNG_QUERY_URL=http://192.168.50.129:8080/search

# ── Soulseek (slskd) ───────────────────────────────────────────
SLSKD_SLSK_USERNAME=your-soulseek-username
SLSKD_SLSK_PASSWORD=

# ── Foundry VTT ────────────────────────────────────────────────
FOUNDRY_USERNAME=your-foundry-username
FOUNDRY_ADMIN_KEY=
FOUNDRY_PASSWORD=

# ── Camofox ──────────────────────────────────
CAMOFOX_VNC_PASSWORD=

# ── VPN Gateway ──────────────────────────────────
# VPN service provider for network-isolated services.
# Create these files:
#   echo "<username>" > ./secrets/vpn_user
#   echo "<password>" > ./secrets/vpn_password
# These are mounted as Docker secrets, not env vars.
VPN_SERVICE_PROVIDER=
VPN_TYPE=openvpn
